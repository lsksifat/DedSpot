# ---------------------------------------------------------------------------
# DedSpot environment variables.
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# PostgreSQL + PostGIS connection string.
# Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgres://dedspot:dedspot_dev_pw@localhost:5432/dedspot"

# Public site URL (used for absolute links / metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public brand name shown in the UI (easy to rebrand later).
NEXT_PUBLIC_BRAND="DedSpot"

# Overpass API endpoint for the OSM ingestion job (daily auto-update).
OVERPASS_URL="https://overpass-api.de/api/interpreter"

# Salt for hashing IPs in abuse controls. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- Authentication (Google sign-in) -----------------------------------------
# Base URL of the app for NextAuth callbacks.
NEXTAUTH_URL="http://localhost:3000"
# Secret used to sign auth session tokens. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Google OAuth credentials from Google Cloud Console (see README).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Comma-separated emails auto-granted the 'admin' role on sign-in.
ADMIN_EMAILS="sifatbabor03@gmail.com"

# --- Automated daily update (OSM ingest) -------------------------------------
# Secret that protects the /api/cron/ingest endpoint from public abuse.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=""
